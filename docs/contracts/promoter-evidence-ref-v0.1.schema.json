{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/contracts/promoter-evidence-ref-v0.1.schema.json",
  "title": "AO Promoter Evidence Reference v0.1",
  "type": "object",
  "required": [
    "role",
    "path",
    "schema_version",
    "sha256",
    "status",
    "candidate_id",
    "created_at_utc",
    "expires_at_utc",
    "authority"
  ],
  "properties": {
    "role": { "type": "string" },
    "path": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "ao.promoter.evidence-ref.v0.1" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": {
      "enum": ["passed", "ready", "allowed", "verified", "blocked", "failed"]
    },
    "candidate_id": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string" },
    "expires_at_utc": { "type": "string" },
    "authority": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
