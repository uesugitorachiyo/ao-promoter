{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/contracts/promoter-live-mutation-boundary-v0.1.schema.json",
  "title": "AO Promoter Live Mutation Boundary v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "current_mutation_class",
    "next_mutation_class",
    "class_promotion_readiness",
    "safe_to_promote_next_class",
    "gate_results",
    "blockers",
    "required_followups",
    "live_mutation_activation_allowed",
    "dry_run_only",
    "mutates_live_state",
    "mutates_repositories",
    "schedules_work",
    "executes_work",
    "approves_work",
    "provider_calls_allowed",
    "release_or_publish_allowed",
    "operator_approval_still_required",
    "first_tiny_live_class_still_gated"
  ],
  "properties": {
    "schema_version": { "const": "ao.promoter.live-mutation-boundary.v0.1" },
    "status": { "enum": ["passed", "failed"] },
    "current_mutation_class": {
      "enum": [
        "docs_only_single_file",
        "docs_only_multi_file",
        "docs_config_only",
        "test_only",
        "low_risk_code",
        "multi_repo_low_risk",
        "complex_repo_mutation"
      ]
    },
    "next_mutation_class": {
      "enum": [
        "docs_only_multi_file",
        "docs_config_only",
        "test_only",
        "low_risk_code",
        "multi_repo_low_risk",
        "complex_repo_mutation"
      ]
    },
    "class_promotion_readiness": {
      "type": "object",
      "required": [
        "status",
        "current_class",
        "next_class",
        "expected_next_class",
        "completed_live_rehearsal",
        "rollback_proof",
        "clean_main_ci",
        "active_holds_clear",
        "denied_reasons",
        "fully_unsupervised_claimed"
      ],
      "properties": {
        "status": { "enum": ["ready", "denied"] },
        "current_class": { "type": "string" },
        "next_class": { "type": "string" },
        "expected_next_class": { "type": "string" },
        "completed_live_rehearsal": { "type": "boolean" },
        "rollback_proof": { "type": "boolean" },
        "clean_main_ci": { "type": "boolean" },
        "active_holds_clear": { "type": "boolean" },
        "promotion_prerequisite_requirements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "promotion_prerequisites": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "successful_test_only_live_evidence": { "type": "boolean" },
            "rollback_fixture": { "type": "boolean" },
            "sentinel_clear_verdict": { "type": "boolean" },
            "clean_main_ci": { "type": "boolean" },
            "exact_covenant_class_ticket": { "type": "boolean" },
            "command_readback": { "type": "boolean" }
          }
        },
        "denied_reasons": { "type": "array" },
        "fully_unsupervised_claimed": { "const": false }
      },
      "additionalProperties": true
    },
    "safe_to_promote_next_class": { "type": "boolean" },
    "gate_results": { "type": "array" },
    "blockers": { "type": "array" },
    "required_followups": { "type": "array" },
    "live_mutation_activation_allowed": { "type": "boolean" },
    "dry_run_only": { "const": true },
    "mutates_live_state": { "const": false },
    "mutates_repositories": { "const": false },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "provider_calls_allowed": { "const": false },
    "release_or_publish_allowed": { "const": false },
    "operator_approval_still_required": { "const": true },
    "first_tiny_live_class_still_gated": { "const": true }
  },
  "additionalProperties": true
}
